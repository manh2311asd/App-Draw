<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#F0F0F0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:scaleType="centerCrop"
            android:background="#F5F5F5"
            app:tint="#E0E0E0"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vẽ mầm cây"
                android:textSize="13sp"
                android:textColor="@color/text_dark"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="25/06 19:00"
                android:textSize="11sp"
                android:textColor="@color/text_dark"
                android:layout_marginTop="4dp"
                app:drawableStartCompat="@android:drawable/ic_menu_today"
                app:drawableTint="@color/text_dark"
                android:drawablePadding="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Zoom"
                android:textSize="11sp"
                android:textColor="@color/text_dark"
                android:layout_marginTop="2dp"
                app:drawableStartCompat="@android:drawable/ic_menu_camera"
                app:drawableTint="@color/text_dark"
                android:drawablePadding="6dp"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:text="Đăng kí"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@color/primary_blue"
                android:textAllCaps="false"
                app:cornerRadius="18dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>