<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_challenge_detail"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:contentInsetStartWithNavigation="0dp"
            app:navigationIcon="@drawable/ic_back">

            <TextView
                android:id="@+id/tv_challenge_detail_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nặn đất sét sáng tạo"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal">
                

                <ImageView
                    android:id="@+id/iv_challenge_more"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_more_vert"
                    app:tint="#333333"
                    android:visibility="gone"/>
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- Banner Image -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_challenge_banner"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#EEF2F9"
                app:strokeWidth="1dp">
                
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    
                    <ImageView
                        android:id="@+id/iv_challenge_banner_img"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/banner_watercolor" />
                        
                    <!-- Mockup overlay: Deadline -->
                    <TextView
                        android:id="@+id/tv_challenge_deadline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="12dp"
                        android:background="@drawable/rounded_bg_white_trans"
                        android:backgroundTint="#F2FFFFFF"
                        android:text="Deadline: 3 ngày còn lại"
                        android:textColor="#333333"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"/>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Status Section -->
            <LinearLayout
                android:id="@+id/ll_top_status_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_community"
                        app:tint="#1A1A1A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Trạng thái: "
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"
                        android:textSize="13sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đã tham gia"
                        android:textColor="#4CAF50"
                        android:textStyle="bold"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_video"
                        app:tint="#666666" />
                    <TextView
                        android:id="@+id/tv_submission_status_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Bài của bạn : Đã nộp . Đang chờ kết quả"
                        android:textColor="#666666"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8EAF6" />

            <!-- Rules Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        app:tint="#1A1A1A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Luật chơi"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </LinearLayout>
                <TextView
                    android:id="@+id/tv_challenge_rules"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="26dp"
                    android:layout_marginTop="4dp"
                    android:text="Đang cập nhật..."
                    android:textSize="12sp"
                    android:textColor="#333333" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Rewards Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="#1A1A1A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Giải thưởng"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_bg_gray"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tv_challenge_rewards"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đang cập nhật..."
                        android:textSize="12sp"
                        android:textColor="#333333" />
                </LinearLayout>
            </LinearLayout>

            <!-- Podium Section -->
            <LinearLayout
                android:id="@+id/ll_podium_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:layout_gravity="center_horizontal">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="#F1C40F" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="BẢNG VÀNG VINH DANH"
                        android:textColor="#F39C12"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:weightSum="3"
                    android:paddingBottom="8dp">

                    <!-- Top 2 (Silver) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥈" android:textSize="20sp"/>
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_top2_avatar"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_marginTop="4dp"
                            android:src="@drawable/ic_default_user"
                            app:shapeAppearanceOverlay="@style/CircleShapeOverlay"
                            app:strokeWidth="2dp"
                            app:strokeColor="#BDC3C7"/>
                        <TextView
                            android:id="@+id/tv_top2_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-" 
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:layout_marginTop="4dp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tv_top2_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="- xp"
                            android:textColor="#A0A0A0"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Top 1 (Gold) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginBottom="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👑" android:textSize="28sp"/>
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_top1_avatar"
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:layout_marginTop="4dp"
                            android:src="@drawable/ic_default_user"
                            app:shapeAppearanceOverlay="@style/CircleShapeOverlay"
                            app:strokeWidth="3dp"
                            app:strokeColor="#F1C40F"/>
                        <TextView
                            android:id="@+id/tv_top1_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-" 
                            android:textSize="14sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:layout_marginTop="4dp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tv_top1_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="- xp"
                            android:textColor="#F39C12"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Top 3 (Bronze) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥉" android:textSize="20sp"/>
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_top3_avatar"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_marginTop="4dp"
                            android:src="@drawable/ic_default_user"
                            app:shapeAppearanceOverlay="@style/CircleShapeOverlay"
                            app:strokeWidth="2dp"
                            app:strokeColor="#CD7F32"/>
                        <TextView
                            android:id="@+id/tv_top3_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-" 
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:layout_marginTop="4dp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tv_top3_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="- xp"
                            android:textColor="#CD7F32"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <View android:id="@+id/v_podium_divider" android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:visibility="gone"/>

            <!-- Entry Submission List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_video"
                        app:tint="#1A1A1A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Bài dự thi"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_public_submissions_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Dynamic entries will be added here -->
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_view_more_entries"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:text="Xem thêm bài dự thi"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:background="@drawable/rounded_blue_gradient"
                    android:paddingHorizontal="24dp"
                    app:backgroundTint="@null"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/ll_joined_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_submission_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Bài của bạn : Chưa nộp"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit_challenge"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="NỘP BÀI"
            app:cornerRadius="28dp"
            app:backgroundTint="#4272D0" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_join_challenge"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:text="THAM GIA THỬ THÁCH"
        android:visibility="gone"
        app:cornerRadius="28dp"
        app:backgroundTint="#4272D0" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
