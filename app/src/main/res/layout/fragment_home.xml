<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                app:cardCornerRadius="26dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:id="@+id/iv_avatar_home"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:scaleType="centerCrop"/>
            </androidx.cardview.widget.CardView>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp">

                <TextView
                     android:id="@+id/tv_subtitle"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="Sáng tạo mỗi ngày,"
                     android:textSize="12sp"
                     android:textColor="#888888"
                     android:fontFamily="sans-serif-medium"
                     android:layout_marginBottom="2dp"
                     app:layout_constraintTop_toTopOf="parent"
                     app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manh!"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#202124"
                    android:fontFamily="sans-serif-black"
                    android:lines="1"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginEnd="6dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/layout_badge_mentor"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constrainedWidth="true" />
                
                <LinearLayout
                    android:id="@+id/layout_badge_mentor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:background="@drawable/rounded_bg_gray"
                    android:backgroundTint="#FFECB3"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    app:layout_constraintTop_toTopOf="@id/tv_greeting"
                    app:layout_constraintBottom_toBottomOf="@id/tv_greeting"
                    app:layout_constraintStart_toEndOf="@id/tv_greeting"
                    app:layout_constraintEnd_toEndOf="parent">
                    
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/star_on"
                        android:layout_marginEnd="4dp"
                        app:tint="#FFA000"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mentor"
                        android:textSize="12sp"
                        android:textColor="#D84315"
                        android:textStyle="bold"
                        android:lines="1"
                        android:maxLines="1"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:id="@+id/btn_notifications"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_notifications"
                    android:padding="4dp"
                    app:tint="@color/text_gray"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>

                <View
                    android:id="@+id/notification_badge"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/ic_badge_red"
                    android:visibility="gone"/>
            </FrameLayout>

            <ImageView
                android:id="@+id/btn_livestream"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_live_tv"
                android:padding="4dp"
                app:tint="#D32F2F"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"/>
                
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Banner Vẽ Ngay Section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="8dp"
                    app:strokeWidth="0dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#DCECFF">

                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/guideline_banner"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintGuide_percent="0.55" />

                        <TextView
                            android:id="@+id/txtBannerTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vẽ ngay"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="#191C1E"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginStart="24dp"
                            android:layout_marginTop="28dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <TextView
                            android:id="@+id/txtBannerSub"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Khơi nguồn sáng tạo không giới hạn"
                            android:textColor="#5F6368"
                            android:textSize="13sp"
                            android:layout_marginTop="6dp"
                            android:layout_marginEnd="8dp"
                            app:layout_constraintStart_toStartOf="@id/txtBannerTitle"
                            app:layout_constraintTop_toBottomOf="@id/txtBannerTitle"
                            app:layout_constraintEnd_toStartOf="@id/guideline_banner"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStartDrawingFragment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bắt đầu vẽ"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#4A6572"
                            app:cornerRadius="24dp"
                            android:paddingHorizontal="24dp"
                            android:layout_marginBottom="24dp"
                            app:elevation="4dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="@id/txtBannerTitle"/>

                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:src="@drawable/img_start_drawing"
                            android:scaleType="centerCrop"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/guideline_banner"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Lịch của bạn Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="32dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lịch của bạn"
                        android:fontFamily="sans-serif-black"
                        android:textSize="20sp"
                        android:textColor="#191C1E"
                        android:drawablePadding="10dp"
                        app:drawableStartCompat="@android:drawable/ic_menu_today"
                        app:drawableTint="#5C6BC0"/>
                    <TextView
                        android:id="@+id/tv_view_calendar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lịch chi tiết"
                        android:textSize="14sp"
                        android:textColor="#5C6BC0"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"/>
                </LinearLayout>

                <!-- View container for dynamic Lịch của bạn -->
                <LinearLayout
                    android:id="@+id/ll_my_schedule_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">
                    
                    <TextView
                         android:id="@+id/tv_empty_schedule"
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:text="Khơi nguồn sáng tạo trong bạn..."
                         android:gravity="center"
                         android:textSize="14sp"
                         android:textColor="#888888"
                         android:padding="24dp"
                         android:visibility="visible"/>
                         
                    <!-- Will add a dynamic FrameLayout or place the adapter here -->
                    <androidx.recyclerview.widget.RecyclerView
                         android:id="@+id/rv_home_my_schedule"
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:clipToPadding="false"
                         android:paddingEnd="16dp"
                         android:orientation="horizontal"
                         app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                         android:overScrollMode="never"
                         android:nestedScrollingEnabled="false"
                         android:visibility="gone"/>
                </LinearLayout>

                <!-- Bài học gợi ý Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView 
                        android:id="@+id/tv_suggested_lessons_title" 
                        android:layout_width="0dp" 
                        android:layout_height="wrap_content" 
                        android:layout_weight="1" 
                        android:text="Bài học gợi ý" 
                        android:fontFamily="sans-serif-black" 
                        android:textSize="20sp" 
                        android:textColor="#191C1E"/>
                    <ImageView
                        android:id="@+id/tv_view_all_lessons"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_media_next"
                        android:padding="4dp"
                        app:tint="#888888"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"/>
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none">
                    <LinearLayout
                        android:id="@+id/ll_suggested_lessons_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Thử Thách Tuần Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Thử Thách Tuần" android:fontFamily="sans-serif-black" android:textSize="20sp" android:textColor="#191C1E"/>

                    <ImageView
                        android:id="@+id/btn_add_challenge"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_input_add"
                        android:padding="6dp"
                        android:visibility="gone"
                        android:layout_marginEnd="8dp"
                        app:tint="@color/primary_blue"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"/>

                    <ImageView
                        android:id="@+id/tv_view_all_challenges"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_media_next"
                        android:padding="4dp"
                        app:tint="#888888"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"/>
                </LinearLayout>

                <!-- Dynamic Challenges Section -->
                <LinearLayout
                    android:id="@+id/ll_challenges_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">
                </LinearLayout>

                <!-- Bài học yêu thích Section -->
                <LinearLayout
                    android:id="@+id/ll_saved_lessons_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Bài học yêu thích" android:fontFamily="sans-serif-black" android:textSize="20sp" android:textColor="#191C1E"/>
                    <ImageView
                        android:id="@+id/tv_view_all_saved_lessons"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_media_next"
                        android:padding="4dp"
                        app:tint="#888888"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"/>
                </LinearLayout>

                <HorizontalScrollView
                    android:id="@+id/hsv_saved_lessons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none">
                    <LinearLayout
                        android:id="@+id/ll_saved_lessons_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingEnd="16dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal">
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Sự kiện sắp tới Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sự kiện sắp tới" android:fontFamily="sans-serif-black" android:textSize="20sp" android:textColor="#191C1E"/>
                    <ImageView
                        android:id="@+id/btn_add_event"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_input_add"
                        android:padding="6dp"
                        android:visibility="gone"
                        android:layout_marginEnd="8dp"
                        app:tint="@color/primary_blue"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"/>
                    <ImageView
                        android:id="@+id/tv_view_all_events"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_media_next"
                        android:padding="4dp"
                        app:tint="#888888"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_home_explore_events"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false"
                    android:paddingEnd="16dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <View android:layout_width="match_parent" android:layout_height="100dp"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</FrameLayout>
