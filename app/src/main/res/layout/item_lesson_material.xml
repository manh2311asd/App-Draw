<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="90dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:orientation="vertical"
    android:gravity="center">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_material_card"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:strokeColor="#4CAF50">
        <ImageView
            android:id="@+id/iv_material"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/banner_watercolor"/>
            
        <View
            android:id="@+id/view_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#804CAF50"
            android:visibility="gone"/>
            
        <ImageView
            android:id="@+id/iv_check"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/checkbox_on_background"
            app:tint="@color/white"
            android:layout_gravity="center"
            android:visibility="gone"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_material_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Màu nước"
        android:textSize="12sp"
        android:textColor="#333333"
        android:gravity="center"
        android:background="@drawable/rounded_bg_white_border"
        android:paddingVertical="4dp"/>
</LinearLayout>
