<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_notif_avatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_default_user" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_notif_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông báo mới"
            android:textSize="14sp"
            android:textColor="#333333" />

        <TextView
            android:id="@+id/tv_notif_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vừa xong"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_notif_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Theo dõi lại"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="@drawable/rounded_bg_blue"
        android:visibility="gone"
        android:layout_marginStart="8dp" />

</LinearLayout>
