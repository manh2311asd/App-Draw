<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/backgroud_app_draw"
        android:alpha="0.4"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="300dp">

            <ImageView
                android:id="@+id/iv_doing_main"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/tp_trending_1" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_back_doing"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_back"
                    app:tint="#333333"/>
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="-24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#4272D0"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#F8FAFF">

                <TextView
                    android:id="@+id/tv_doing_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tranh sơn dầu vẽ núi"
                    android:textColor="#1A1A1A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_doing_goal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Mục tiêu : Vẽ"
                    android:textColor="#555555"
                    android:textSize="14sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="#DDDDDD" />

                <!-- Thêm thanh tiến độ liên kết với Checklist -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical">
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/pb_checklist_progress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:progress="60"
                        app:trackThickness="8dp"
                        app:trackCornerRadius="4dp"
                        app:indicatorColor="#4272D0"/>
                    <TextView
                        android:id="@+id/tv_checklist_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="60%"
                        android:textColor="#4272D0"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <CheckBox
                        android:id="@+id/cb_step1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phác thảo ý tưởng"
                        android:checked="true"
                        android:textColor="#333333"/>
                    <CheckBox
                        android:id="@+id/cb_step2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chuẩn bị vật liệu"
                        android:checked="true"
                        android:textColor="#333333"/>
                    <CheckBox
                        android:id="@+id/cb_step3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Vẽ nền"
                        android:checked="true"
                        android:textColor="#333333"/>
                    <CheckBox
                        android:id="@+id/cb_step4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tô màu chính"
                        android:textColor="#333333"/>
                    <CheckBox
                        android:id="@+id/cb_step5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hoàn thiện chi tiết"
                        android:textColor="#333333"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_continue_drawing"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Tiếp tục vẽ"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:backgroundTint="#4272D0"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</FrameLayout>
