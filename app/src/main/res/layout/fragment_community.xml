<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FE">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="#FFFFFF">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cộng đồng"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#333333"/>
        <ImageView
            android:id="@+id/btn_notifications_community"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_popup_reminder"
            app:tint="#333333"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </RelativeLayout>

    <!-- Tabs (Khám phá, Tác phẩm, etc.) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:paddingBottom="8dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">
            <TextView
                android:id="@+id/tv_comm_explore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khám phá"
                android:textColor="#4272D0"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="12dp"
                android:background="@drawable/selected_tool_bg"
                android:clickable="true"
                android:focusable="true"/>
            <TextView
                android:id="@+id/tv_comm_works"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tác phẩm"
                android:textColor="#888888"
                android:textSize="16sp"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView
                android:id="@+id/tv_comm_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiến độ"
                android:textColor="#888888"
                android:textSize="16sp"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView
                android:id="@+id/tv_comm_tips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tips"
                android:textColor="#888888"
                android:textSize="16sp"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Filters -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/chip_comm_topic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chủ đề"
                    android:background="@drawable/bg_chip_selected"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:id="@+id/chip_comm_watercolor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Màu nước"
                    android:layout_marginStart="8dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>
                <TextView
                    android:id="@+id/chip_comm_sketch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phác thảo"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_selected"
                    android:backgroundTint="#FFE082"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textColor="#795548"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_comm_filter_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang lọc : Phác thảo ✕"
                android:textSize="14sp"
                android:textColor="#333333"
                android:background="@drawable/rounded_bg_white_border"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:clickable="true"
                android:focusable="true"/>
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
            <TextView
                android:id="@+id/tv_comm_sort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mới nhất ▼"
                android:textSize="14sp"
                android:textColor="#333333"
                android:background="@drawable/rounded_bg_white_border"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Post Feed -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:id="@+id/ll_post_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">
            <!-- Post items will be included here -->
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
