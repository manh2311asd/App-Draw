<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/backgroud_app_draw" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@android:color/transparent">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="20dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:clipToPadding="false">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cộng đồng"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#192A56"/>
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_notifications_community"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F0F4FA"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="#4272D0"/>
        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>

    <!-- Filters -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:paddingBottom="8dp"
        android:elevation="4dp"
        android:clipToPadding="false">
        <LinearLayout
            android:id="@+id/ll_filter_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">
            
            <TextView
                android:id="@+id/tv_filter_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tất cả"
                android:background="@drawable/rounded_bg_gray"
                android:backgroundTint="#4272D0"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>
                
            <TextView
                android:id="@+id/tv_filter_watercolor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Màu nước"
                android:background="@drawable/rounded_bg_gray"
                android:textColor="#333333"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>
                
            <TextView
                android:id="@+id/tv_filter_sketch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phác thảo"
                android:background="@drawable/rounded_bg_gray"
                android:textColor="#333333"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>
                
            <TextView
                android:id="@+id/tv_filter_handmade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thủ công"
                android:background="@drawable/rounded_bg_gray"
                android:textColor="#333333"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>
                
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Post Feed -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="8dp">
        <LinearLayout
            android:id="@+id/ll_post_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">
            <!-- Post items will be included here -->
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
</FrameLayout>
