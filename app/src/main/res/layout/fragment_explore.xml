<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Khám phá"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <!-- Search Bar -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_search"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="#FFFFFF">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_search"
                    app:tint="#888888"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tìm bài học, dự án..."
                    android:textSize="13sp"
                    android:layout_marginStart="12dp"
                    android:textColor="#9E9E9E"/>
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="#888888"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Category Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/chip_topic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chủ đề"
                    android:background="@drawable/bg_chip_selected"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:id="@+id/chip_technique"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kỹ thuật"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/rounded_bg_white"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:id="@+id/chip_materials"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vật liệu"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/rounded_bg_white"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:id="@+id/chip_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/rounded_bg_white"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Banner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/banner_watercolor"
                    android:scaleType="centerCrop"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Watercolor Week"
                        android:textSize="28sp"
                        android:textStyle="italic"
                        android:textColor="#4834DF"
                        android:fontFamily="serif"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Khám phá các loại bài giảng, dự án \n&amp; thử thách về màu nước !"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_explore_now"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="16dp"
                        android:text="Khám phá ngay >"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        app:backgroundTint="#5C6BC0"
                        app:cornerRadius="20dp"
                        android:paddingHorizontal="24dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"/>
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Section: Chủ đề -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chủ đề"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem tất cả >"
                android:textColor="#666666"
                android:textSize="12sp"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none"
            android:clipToPadding="false">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <include layout="@layout/item_explore_category" android:id="@+id/topic_1"/>
                <include layout="@layout/item_explore_category" android:id="@+id/topic_2"/>
                <include layout="@layout/item_explore_category" android:id="@+id/topic_3"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Section: Nghệ sĩ nổi bật -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nghệ sĩ nổi bật"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem tất cả >"
                android:textColor="#666666"
                android:textSize="12sp"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none"
            android:clipToPadding="false">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <include layout="@layout/item_artist" android:id="@+id/artist_1"/>
                <include layout="@layout/item_artist" android:id="@+id/artist_2"/>
                <include layout="@layout/item_artist" android:id="@+id/artist_3"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Section: Tác phẩm Trending -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tác phẩm Trending"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem tất cả >"
                android:textColor="#666666"
                android:textSize="12sp"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none"
            android:clipToPadding="false">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <include layout="@layout/item_trending" android:id="@+id/trending_1"/>
                <include layout="@layout/item_trending" android:id="@+id/trending_2"/>
            </LinearLayout>
        </HorizontalScrollView>

        <View android:layout_width="match_parent" android:layout_height="100dp"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
